		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/js-cookie": "^3.0.6",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"eslint": "^10.2.0",
