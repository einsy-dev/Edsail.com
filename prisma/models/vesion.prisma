model Version {
  id       String  @id @default(cuid())
  major    Int
  minor    Int
  patch    Int
  policy   Policy? @relation(fields: [policyId], references: [id])
  policyId String?
  file     File?   @relation(fields: [fileId], references: [id])
  fileId   String?

  @@unique([policyId, major, minor, patch])
  @@unique([fileId, major, minor, patch])
}
